# =============================================
# Tibby Chatbot — Environment Variables
# =============================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# Flask debug mode (set to true only in local dev)
FLASK_DEBUG=false

# The URL of your deployed frontend (for CORS allow-list)
# Example: https://tibby-chatbot.vercel.app
FRONTEND_URL=

# Port the server listens on (Render sets this automatically)
PORT=5000
